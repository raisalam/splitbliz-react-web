# Backend API base URL (Spring Boot, context path /v1)
VITE_API_BASE_URL=http://localhost:8080/v1

# App display name
VITE_APP_NAME=SplitBliz

# MQTT WebSocket URL for real-time group hints
VITE_MQTT_URL=wss://mqtt.splitbliz.com/mqtt

# Firebase — used for Remote Config (kill switch, maintenance mode, force update)
# and push notification registration
VITE_FIREBASE_API_KEY=REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_ME
VITE_FIREBASE_PROJECT_ID=REPLACE_ME
VITE_FIREBASE_APP_ID=REPLACE_ME
VITE_FIREBASE_MEASUREMENT_ID=REPLACE_ME
